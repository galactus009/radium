<?xml version="1.0" encoding="UTF-8"?>
<CONFIG>
  <ProjectOptions>
    <Version Value="12"/>
    <PathDelim Value="/"/>
    <General>
      <Flags>
        <MainUnitHasCreateFormStatements Value="True"/>
        <MainUnitHasTitleStatement Value="False"/>
        <MainUnitHasScaledStatement Value="False"/>
      </Flags>
      <SessionStorage Value="InProjectDir"/>
      <Title Value="Radium"/>
      <UseAppBundle Value="True"/>
      <ResourceType Value="res"/>
    </General>
    <BuildModes>
      <Item Name="Default" Default="True"/>
    </BuildModes>
    <PublishOptions>
      <Version Value="2"/>
      <UseFileFilters Value="True"/>
    </PublishOptions>
    <RunParams>
      <FormatVersion Value="2"/>
    </RunParams>
    <RequiredPackages>
      <Item>
        <PackageName Value="LCL"/>
      </Item>
    </RequiredPackages>
    <Units>
      <Unit>
        <Filename Value="Radium.lpr"/>
        <IsPartOfProject Value="True"/>
      </Unit>
      <Unit>
        <Filename Value="../Source/Gui/Radium.Gui.MainForm.pas"/>
        <IsPartOfProject Value="True"/>
        <ComponentName Value="MainForm"/>
        <HasResources Value="True"/>
        <ResourceBaseClass Value="rtForm"/>
        <UnitName Value="Radium.Gui.MainForm"/>
      </Unit>
    </Units>
  </ProjectOptions>
  <CompilerOptions>
    <Version Value="11"/>
    <PathDelim Value="/"/>
    <Target>
      <Filename Value="../Bin/Radium"/>
    </Target>
    <SearchPaths>
      <IncludeFiles Value="$(ProjOutDir)"/>
      <OtherUnitFiles Value="../Source/Gui;../Source/Cid;../Source/Api;../Source/Types;$(MORMOT2)/src/core;$(MORMOT2)/src/lib;$(MORMOT2)/src/net;$(MORMOT2)/src/crypt;$(MORMOT2)/src/db;$(MORMOT2)/src/orm;$(MORMOT2)/src/rest;$(MORMOT2)/src/soa;$(MORMOT2)/src/app;$(MORMOT2)/src/misc"/>
      <UnitOutputDirectory Value="../Lib"/>
    </SearchPaths>
    <Parsing>
      <SyntaxOptions>
        <SyntaxMode Value="Delphi"/>
        <CStyleOperator Value="False"/>
        <UseAnsiStrings Value="False"/>
      </SyntaxOptions>
    </Parsing>
    <CodeGeneration>
      <Optimizations>
        <OptimizationLevel Value="2"/>
      </Optimizations>
    </CodeGeneration>
    <Linking>
      <Debugging>
        <DebugInfoType Value="dsDwarf3"/>
      </Debugging>
    </Linking>
    <Other>
      <CustomOptions Value="-WM10.13"/>
    </Other>
  </CompilerOptions>
</CONFIG>
